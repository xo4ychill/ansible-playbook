# 🔐 Секреты (НИКОГДА не коммитьте этот файл в репозиторий!)
CLICKHOUSE_PASSWORD=your_strong_password_here

# 🌍 Окружение
ENV=prod
DEBUG_MODE=false

# 🌐 Сеть
ANSIBLE_SSH_TIMEOUT=45
ANSIBLE_FORKS=10

# 🗄️ ClickHouse
CLICKHOUSE_PRIMARY_IP=10.10.10.14
CLICKHOUSE_DATABASE=logs
CLICKHOUSE_TABLE=events

# 📤 Vector
VECTOR_VERSION=0.37.1
VECTOR_BATCH_MAX_EVENTS=5000

# 🌐 Lighthouse
LIGHTHOUSE_DOMAIN=logs.example.com
LIGHTHOUSE_SSL_ENABLED=false