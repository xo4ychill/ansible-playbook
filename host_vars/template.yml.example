# =============================================================================
# host_vars/template.yml.example — Шаблон для хост-специфичных переменных
# 💡 Скопируйте этот файл для каждого хоста, замените значения и зашифруйте через Vault
# =============================================================================
---
# 🌐 IP-адрес хоста (задаётся через ENV или переменную)
# ❌ Не пишите реальный IP напрямую в файл!
ansible_host: >-
  {{ 
    lookup('env', 'HOST_IP') 
    | default('127.0.0.1', true) 
  }}

# 🔐 Если нужен уникальный пароль для хоста — используйте Vault
# custom_password: "{{ vault_custom_password }}"

# 🐧 Семейство ОС (если отличается от группового)
ansible_os_family_override: >-
  {{ 
    lookup('env', 'HOST_OS_FAMILY') 
    | default('', true) 
  }}

# 📦 Хост-специфичные параметры (опционально)
# Пример для Vector: кастомные источники логов
# vector_custom_sources:
#   - type: file
#     include: "/var/log/myapp/*.log"
#     decoding: { codec: "json" }

# 💡 Все чувствительные данные должны быть зашифрованы:
# Для шифрования:
#   1. Создайте файл: cp template.yml.example clickhouse-primary.yml
#   2. Заполните значения
#   3. Зашифруйте: ansible-vault encrypt host_vars/clickhouse-primary.yml
#   4. При запуске: ansible-playbook ... --ask-vault-pass