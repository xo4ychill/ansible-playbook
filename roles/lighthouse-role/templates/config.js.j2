// =============================================================================
// Lighthouse configuration (generated by Ansible)
// Файл: roles/lighthouse/templates/config.js.j2
// Назначение: подключение фронтенда к ClickHouse через Nginx proxy
// =============================================================================

window.LIGHTHOUSE_CONFIG = {
  // 🔗 ClickHouse connection settings
  clickhouse: {
    // 💡 Браузер делает запросы на /api/clickhouse, Nginx проксирует на реальный endpoint
    endpoint: "{{ lighthouse_clickhouse_api_url }}",
    
    // Параметры подключения (для reference)
    host: "{{ lighthouse_clickhouse_host }}",
    port: {{ lighthouse_clickhouse_port }},
    database: "{{ lighthouse_clickhouse_database }}",
    table: "{{ lighthouse_clickhouse_table }}",
    user: "{{ lighthouse_clickhouse_user }}",
    
    // ⚠️ Пароль НЕ передаётся в браузер! Только для бэкенд-прокси в Nginx
  },
  
  // 📊 Настройки авто-обновления дашборда
  refreshInterval: {{ lighthouse_ui_refresh_interval }},
  
  // 🎨 Интерфейс: тема и часовой пояс
  theme: '{{ lighthouse_ui_theme }}',
  timezone: '{{ lighthouse_ui_timezone }}'
};