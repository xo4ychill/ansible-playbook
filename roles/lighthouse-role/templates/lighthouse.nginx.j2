# =============================================================================
# Nginx configuration for Lighthouse + ClickHouse proxy
# Файл: roles/lighthouse/templates/lighthouse.nginx.j2
# =============================================================================

server {
    listen {{ lighthouse_nginx_port }} default_server;
    listen [::]:{{ lighthouse_nginx_port }} default_server;
    server_name {{ lighthouse_nginx_server_name }};

    root {{ lighthouse_nginx_root }};
    index index.html index.htm;

    access_log {{ lighthouse_nginx_log_dir }}/access.log combined;
    error_log {{ lighthouse_nginx_log_dir }}/error.log warn;

    # 🗂️ Раздача статических файлов
    location / {
        try_files $uri $uri/ =404;
        autoindex off;
        
        # 🛡️ Security headers
        {% for header, value in lighthouse_nginx_security_headers.items() %}
        add_header {{ header }} "{{ value }}" always;
        {% endfor %}
        server_tokens off;
    }

    # 🔗 Proxy для API-запросов к ClickHouse
    location {{ lighthouse_clickhouse_api_url }} {
        proxy_pass {{ clickhouse_protocol }}://{{ lighthouse_clickhouse_host }}:{{ lighthouse_clickhouse_port }};
        
        proxy_set_header Host $host;
        proxy_set_header X-Real-IP $remote_addr;
        proxy_set_header X-Forwarded-For $proxy_add_x_forwarded_for;
        proxy_set_header X-Forwarded-Proto $scheme;
        
        proxy_connect_timeout {{ lighthouse_proxy_timeout }}s;
        proxy_send_timeout {{ lighthouse_proxy_timeout }}s;
        proxy_read_timeout {{ lighthouse_proxy_timeout }}s;
        
        proxy_buffering off;
        
        limit_except GET POST {
            deny all;
        }
    }

    # 🚫 Запрет доступа к скрытым файлам
    location ~ /\. {
        deny all;
        access_log off;
        log_not_found off;
    }

    # 🗑️ Не логировать запросы к статике
    location ~* \.(jpg|jpeg|png|gif|ico|css|js|svg|woff2?)$ {
        access_log off;
        expires 30d;
        add_header Cache-Control "public, immutable";
    }
}